<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="stock-assignment-order"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">
    <!-- DejaVu Sans (jasperreports-fonts) supports Serbian Latin: č, ć, ž, š, đ -->
    <style name="Base" isDefault="true" fontName="DejaVu Sans" fontSize="10"
           pdfFontName="DejaVu Sans" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="BaseBold" fontName="DejaVu Sans" fontSize="10" isBold="true"
           pdfFontName="DejaVu Sans" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <style name="Title" fontName="DejaVu Sans" fontSize="18" isBold="true"
           pdfFontName="DejaVu Sans" pdfEncoding="Identity-H" isPdfEmbedded="true"/>
    <parameter name="reportTitle" class="java.lang.String"/>
    <parameter name="labelWorkOrder" class="java.lang.String"/>
    <parameter name="labelPurchaseOrder" class="java.lang.String"/>
    <parameter name="labelCustomer" class="java.lang.String"/>
    <parameter name="labelProduct" class="java.lang.String"/>
    <parameter name="labelRequiredAssigned" class="java.lang.String"/>
    <parameter name="labelAssignedAt" class="java.lang.String"/>
    <parameter name="labelCreatedBy" class="java.lang.String"/>
    <parameter name="labelStockLocation" class="java.lang.String"/>
    <parameter name="labelQuantity" class="java.lang.String"/>
    <parameter name="workOrderId" class="java.lang.String"/>
    <parameter name="purchaseOrderId" class="java.lang.String"/>
    <parameter name="customerName" class="java.lang.String"/>
    <parameter name="productReference" class="java.lang.String"/>
    <parameter name="productName" class="java.lang.String"/>
    <parameter name="requiredQuantity" class="java.lang.String"/>
    <parameter name="assignedTotal" class="java.lang.String"/>
    <parameter name="assignedAt" class="java.lang.String"/>
    <parameter name="createdBy" class="java.lang.String"/>
    <field name="locationCode" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>
    <title>
        <band height="50">
            <textField>
                <reportElement x="0" y="10" width="555" height="30" style="Title"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{reportTitle}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <pageHeader>
        <band height="140">
            <textField>
                <reportElement x="0" y="0" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelWorkOrder} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="0" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{workOrderId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="20" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelPurchaseOrder} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="20" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{purchaseOrderId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="40" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelCustomer} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="40" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{customerName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="60" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelProduct} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="60" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{productReference} + " — " + $P{productName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="80" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelRequiredAssigned} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="80" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{requiredQuantity} + " / " + $P{assignedTotal}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="100" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelAssignedAt} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="100" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{assignedAt}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="120" width="140" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelCreatedBy} + ":"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="140" y="120" width="415" height="18"/>
                <textFieldExpression><![CDATA[$P{createdBy}]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>
    <columnHeader>
        <band height="24">
            <textField>
                <reportElement x="0" y="4" width="380" height="18" style="BaseBold"/>
                <textFieldExpression><![CDATA[$P{labelStockLocation}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="4" width="175" height="18" style="BaseBold"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$P{labelQuantity}]]></textFieldExpression>
            </textField>
        </band>
    </columnHeader>
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="2" width="380" height="16"/>
                <textFieldExpression><![CDATA[$F{locationCode}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="2" width="175" height="16"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
